# PCBuilder Production Environment Variables Template
# DO NOT COMMIT SECRETS TO GIT

ASPNETCORE_ENVIRONMENT=Production

# Database Settings
DB_HOST=prod-db-server-url
DB_PORT=1433
DB_NAME=PCBuilderDb
DB_USER=sa
DB_PASSWORD=

# Cache Settings
