{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Backend",
      "command": "./build.sh",
      "type": "shell",
      "args": ["build", "PCBuilder.sln"],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Test Backend",
      "command": "./build.sh",
      "type": "shell",
      "args": ["test", "PCBuilder.sln"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Docker Compose Up",
      "command": "docker",
      "type": "shell",
      "args": ["compose", "up", "--build", "-d"],
      "problemMatcher": []
    },
    {
      "label": "Docker Compose Down",
      "command": "docker",
      "type": "shell",
      "args": ["compose", "down"],
      "problemMatcher": []
    },
    {
      "label": "Docker Compose Logs",
      "command": "docker",
      "type": "shell",
      "args": ["compose", "logs", "-f"],
      "problemMatcher": []
    }
  ]
}
