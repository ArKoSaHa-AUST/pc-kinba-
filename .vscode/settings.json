{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll.eslint": "explicit"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp",
    "editor.indentSize": 4,
    "editor.tabSize": 4
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.indentSize": 2,
    "editor.tabSize": 2
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.indentSize": 2,
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.indentSize": 2
  },
  "files.associations": {
    "appsettings*.json": "jsonc",
    "*.sql": "sql"
  },
  "files.nesting.enabled": true,
  "files.nesting.patterns": {
    "*.csproj": "${capture}.csproj.user, ${capture}.csproj.nuget.g.props, ${capture}.csproj.nuget.g.targets",
    "package.json": "package-lock.json, tsconfig.json, vite.config.ts, tailwind.config.js, postcss.config.js",
    ".env": ".env.*"
  },
  "dotnet.unitTestDebuggingOptions": {}
}
