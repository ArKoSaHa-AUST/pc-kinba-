# Set default behavior to automatically normalize line endings on check-in
* text=auto

# Enforce LF endings on C# code files
*.cs text eol=lf

# Enforce LF endings on web assets
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf

# Enforce LF endings on scripting and configurations
*.sh text eol=lf
*.ps1 text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.sql text eol=lf
Dockerfile text eol=lf
docker-compose* text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Mark binary files to keep them untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.dll binary
*.pdb binary
*.exe binary
