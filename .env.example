# PCBuilder Global Environment Variables Example
# Copy this file to '.env' and fill in the secrets for local development.

# Database settings
DB_HOST=db
DB_PORT=1433
DB_NAME=PCBuilderDb
DB_USER=sa
DB_PASSWORD=YourStrongPasswordHere!123

# Cache Settings
REDIS_CONNECTION=redis:6379

# JWT Authentication Settings
JWT_SECRET=YourSuperLongAndSecureSecretKeyHereMustBeAtLeast32Chars!
JWT_ISSUER=PCBuilderIssuer
JWT_AUDIENCE=PCBuilderAudience

# AI Module API Keys
OPENAI_API_KEY=your_openai_api_key_placeholder
GROQ_API_KEY=your_groq_api_key_placeholder
GEMINI_API_KEY=your_gemini_api_key_placeholder
